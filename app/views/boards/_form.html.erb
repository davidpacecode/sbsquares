<%= form_with(model: [@game, @board]) do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
    <%= tag.br %>
    <%= form.label :price %>
    <%= form.text_field :price %>
  </div>

  <%= tag.br %>
  <%= form.label :nickname %>
  <%= form.text_field :nickname %>
  <%= tag.br %>

  <div class="wa-grid grid-container">
  <% @board.squares.each do |s| %>
    <div class="grid-item">
      <% if s.user_id.nil? %>
        <wa-checkbox></wa-checkbox>
      <% elsif s.nickname.nil? %>
        <%= "#{s.user_id}" %>
      <% else %>
        <%= "#{s.nickname}" %>
      <% end %>
    </div>
  <% end %>
  </div>

  <div>
    <%= form.submit %>
  </div>
<% end %>
