<%= form_with(model: [@game, @board]) do |form| %>
  <div>
    <%= form.label :name %>
    <%= form.text_field :name %>
    <%= tag.br %>
    <%= form.label :price %>
    <%= form.text_field :price %>
  </div>

  <%= tag.br %>

  <table>
    <thead>
      <tr>
        <th>Name</th>
        <th>Price of Square</th>
        <th>Members</th>
        <th>Actions</th>
      </tr>
    </thead>

    <tbody>
      <% @game.boards.each do |board| %>
        <tr>
          <td><%= board.name %></td>
          <td><%= board.price %></td>
          <td><%= board.users.count %> members</td>
          <td>
            <%= link_to 'Show', board %>
            <%= link_to 'Edit', edit_board_path(board) %>
            <%= link_to 'Delete', board, method: :delete, data: { confirm: 'Are you sure?' } %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>

  <%= tag.br %> 

  <%= link_to 'New Board', new_board_path, class: 'btn btn-primary' %>

  <div>
    <%= form.submit %>
  </div>
<% end %>
